# SmartDocs AI — Project-specific config
# Copy this to .env and fill in your values

# S3
S3_BUCKET_NAME=your-bucket-name-here

# Lambda
LAMBDA_ARN=arn:aws:lambda:us-east-1:your_account_id:function:your-function-name

# API Gateway
API_ID=your_api_id_here
INTEGRATION_ID=your_integration_id_here
INTEGRATION_URL=arn:aws:lambda:us-east-1:your_account_id:function:your-function-name
ROUTE_ID=your_route_id_here

# DynamoDB
DYNAMODB_TABLE_NAME=your_table_name_here
